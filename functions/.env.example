# Firebase Cloud Functions Environment Variables
# Copy this to .env.local and fill in your values

# reCAPTCHA v3 - Get from Google Cloud Console
# Used to verify requests are from legitimate app
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Twilio SMS Configuration (Optional - for SMS backup)
# Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Environment
ENVIRONMENT=production
# Set to 'development' to log OTPs in response

# Firebase Project ID (auto-detected, optional)
FIREBASE_PROJECT_ID=your-project-id
