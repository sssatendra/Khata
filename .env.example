# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Get these values from your Firebase project:
# 1. Go to https://console.firebase.google.com
# 2. Select your project
# 3. Project Settings → Service Accounts → Generate new private key (Web SDK)
# 4. Copy the values below

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id-here
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id-here

# Optional: Firebase Analytics
# FIREBASE_MEASUREMENT_ID=your-measurement-id

# ========================================
# CLOUD FUNCTIONS BACKEND
# ========================================
EXPO_PUBLIC_BACKEND_URL=https://us-central1-yourproject.cloudfunctions.net

# ========================================
# RECAPTCHA (for OTP security)
# ========================================
# Get from https://www.google.com/recaptcha/admin
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ========================================
# SMS NOTIFICATIONS (Optional - Phase 2)
# ========================================
# Twilio configuration for sending payment reminders
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# BARCODE SCANNING (Optional - Phase 2)
# ========================================
# Expo Barcode Scanner - mostly auto-configured
# Set to true to enable barcode mode
EXPO_PUBLIC_ENABLE_BARCODE_SCANNER=false

# ========================================
# VOICE INPUT (Optional - Phase 2)
# ========================================
# Google Speech-to-Text API key
EXPO_PUBLIC_GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key

# ========================================
# APP CONFIGURATION
# ========================================
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_ENVIRONMENT=development
# Set to 'production' for app store builds

